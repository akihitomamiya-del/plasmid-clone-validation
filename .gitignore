# Sequencing data — never commit
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bai
*.sam
*.cram

# Container images
*.sif

# Nextflow runtime
.nextflow/
.nextflow.log*
work/

# Wrapper / pipeline outputs
filtered/
nf_input/
cloneval/
amplicon/
annotation/
runs/
output/
results/

# OS / editor cruft
.DS_Store
*.swp
*~

# Python bytecode cache (e.g. from running amplicon_annotate/merge_report.py)
__pycache__/
*.pyc
*.pyo

# Committed example data (overrides the *.fastq.gz ignore above).
# Recursive so barcodeNN/ subdirs (the layout the scripts require) are tracked too.
!example_rawdata/
!example_rawdata/**

# Committed reference run (EPI2ME canu output, the build's correctness target).
# Re-include dirs first (defeats the bare output/ ignore), then files (defeats *.fastq).
!reference_run_canu/
!reference_run_canu/**/
!reference_run_canu/**

# Committed amplicon example: raw reads (barcode09/) + an EPI2ME wf-amplicon de-novo
# reference run — the amplicon correctness target (docs/amplicon_testing.md). Same pattern
# as reference_run_canu: re-include dirs first (defeats the bare output/ ignore), then files
# (defeats *.fastq.gz / *.bam / *.bai).
!amplicon_test_example/
!amplicon_test_example/**/
!amplicon_test_example/**
