# Sequencing data — never commit
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bai
*.sam
*.cram

# Container images
*.sif

# Nextflow runtime
.nextflow/
.nextflow.log*
work/

# Wrapper / pipeline outputs
filtered/
nf_input/
cloneval/
amplicon/
annotation/
deliverables/
deliverables.zip
runs/
output/
results/

# OS / editor cruft
.DS_Store
*.swp
*~

# Python bytecode cache (e.g. from running amplicon_annotate/merge_report.py)
__pycache__/
*.pyc
*.pyo

# ── Committed example & reference data (all under examples/) ─────────────────────────
# The globals above ignore real data (*.fastq.gz, *.bam, output/, runs/, AND the bare
# `amplicon/` pipeline-output dir-name, etc.). These negations re-include ONLY the shipped
# fixtures under examples/. Order matters (last match wins) and DIRECTORIES must be
# re-included BEFORE files: `!examples/**/` defeats the bare `output/` and `amplicon/`
# dir-ignores so git descends into the nested reference_run_*/output trees;
# `!examples/**` then defeats *.fastq.gz / *.bam / *.fastq.
!examples/
!examples/**/
!examples/**
