{
  // plasmid-clone-validation — DEFAULT config: run the pipeline from the published
  // runtime image (no Claude, no firewall). Two alternatives in the "Reopen in Container" picker:
  //   • .devcontainer/claude-code — the offline yolo-Claude SANDBOX (Claude CLI + egress firewall)
  //   • .devcontainer/build       — build/iterate the runtime image itself
  "name": "plasmid-clone-validation",
  "image": "ghcr.io/akihitomamiya-del/plasmid-clone-validation:latest",

  // Rootless Apptainer runArgs so the workflow's nested containers run offline.
  // HOST PREREQUISITE (one-time, admin): sudo bash .devcontainer/setup-host-apparmor.sh
  //   (loads the pcv-apptainer AppArmor profile; see docs/host_userns_prereq.md). Without it
  //   Docker errors "apparmor profile pcv-apptainer not found". runArgs are IGNORED on Codespaces.
  "runArgs": [
    "--security-opt", "seccomp=unconfined",
    "--security-opt", "apparmor=pcv-apptainer",
    "--security-opt", "systempaths=unconfined",
    "--device", "/dev/fuse"
  ],

  "features": { "ghcr.io/devcontainers/features/github-cli:1": {} },

  // Auto-install VS Code extensions into the container's own server on create.
  // Live Preview (ms-vscode.live-server) renders the workflow HTML report
  // (runs/<out>/cloneval/wf-clone-validation-report.html) in an embedded tab,
  // with its port auto-forwarded to your client. This default config has no
  // egress firewall, so the one-time marketplace install just works on a
  // networked host; afterward the extension serves the report fully offline.
  "customizations": {
    "vscode": { "extensions": ["ms-vscode.live-server"] }
  },

  "containerEnv": {
    "NXF_SINGULARITY_CACHEDIR": "/opt/sif-cache",
    "NXF_HOME": "/opt/nextflow",
    "NXF_OFFLINE": "true"
  },

  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  // The runtime image keeps the devcontainers-base blanket sudo (no agent to contain here), so a
  // plain chown re-aligns /opt to the runtime uid when the host dev-uid != 1000.
  "postStartCommand": "sudo chown -R vscode:vscode /opt/nextflow"
}
