{
  // plasmid-clone-validation — Claude Code SANDBOX (offline yolo-Claude).
  // Builds the thin claude-code layer ON TOP of the published runtime image.
  // Pick this config in "Dev Containers: Reopen in Container" for agent work.
  "name": "plasmid-clone-validation (Claude Code Sandbox)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "../..",
    "args": {
      "TZ": "${localEnv:TZ:UTC}",
      "CLAUDE_CODE_VERSION": "latest"
    }
  },

  // Egress firewall (NET_ADMIN/NET_RAW) + rootless Apptainer on a userns-hardened host
  // (seccomp=unconfined + systempaths=unconfined + /dev/fuse + the custom pcv-apptainer
  // AppArmor profile, NOT apparmor=unconfined). systempaths=unconfined unmasks /proc so the
  // workflow's nested Apptainer can mount a fresh /proc. Container-scoped; far short of --privileged.
  // HOST PREREQUISITE (one-time, admin): sudo bash .devcontainer/setup-host-apparmor.sh
  //   — else Docker errors "apparmor profile pcv-apptainer not found" and the container won't start.
  //   Rationale/trade-off/revert: docs/host_userns_prereq.md.
  // CAVEAT: runArgs are IGNORED by GitHub Codespaces — build locally (VS Code / devcontainer-CLI).
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--security-opt", "seccomp=unconfined",
    "--security-opt", "apparmor=pcv-apptainer",
    "--security-opt", "systempaths=unconfined",
    "--device", "/dev/fuse"
  ],

  "features": { "ghcr.io/devcontainers/features/github-cli:1": {} },

  "containerEnv": {
    "NXF_SINGULARITY_CACHEDIR": "/opt/sif-cache",
    "NXF_HOME": "/opt/nextflow",
    "NXF_OFFLINE": "true",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}"
  },

  // Per-${devcontainerId} volumes → each user/devcontainer gets ISOLATED Claude creds + history.
  // (Docker volumes are daemon-global, so fixed names would collide across users on one host.)
  // Do NOT mount a volume over /opt — the baked SIF cache + pulled workflow live there.
  "mounts": [
    "source=pcv-claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=pcv-bashhistory-${devcontainerId},target=/commandhistory,type=volume"
  ],

  "remoteUser": "vscode",
  // KEEP true: the workspace is bind-mounted from the host, so vscode must match the host uid to
  // write it. Side effect: /opt (baked at build uid 1000) is orphaned when host dev-uid != 1000 —
  // fix-opt-ownership.sh (postStartCommand) re-chowns it to the runtime uid at start.
  "updateRemoteUserUID": true,

  // Install the "Live Preview" extension so the workflow HTML report renders in-editor
  // (right-click runs/<out>/cloneval/wf-clone-validation-report.html -> "Show Preview").
  // Runs in the PRE-firewall window (postCreateCommand precedes postStartCommand). The egress
  // firewall blocks the extension gallery byte-CDN, so the normal marketplace install AND the
  // declarative customizations.vscode.extensions route both fail in this sandbox; instead
  // install-live-preview.sh installs the .vsix baked into the image (Dockerfile) via the
  // headless code-server CLI and verifies. Non-fatal; logs to /tmp/live-preview-install.log.
  // claudeRefresh: pull the latest Claude CLI as root (scoped sudo) in the same pre-firewall window,
  // so the CLI tracks @latest without an image rebuild while staying root-owned/immutable to the
  // agent. The [ -x ] guard is shared with the pull config (here install-claude.sh is always baked
  // in). Best-effort; keeps the baked fallback on failure. See docs/claude_cli_version_handoff.md.
  "postCreateCommand": {
    "livePreview": "bash /usr/local/bin/install-live-preview.sh",
    "claudeRefresh": "if [ -x /usr/local/bin/install-claude.sh ]; then sudo /usr/local/bin/install-claude.sh; fi"
  },

  // postStartCommand entries run in PARALLEL; both use scoped-NOPASSWD sudo (the runtime base's
  // blanket NOPASSWD:ALL is removed in the claude-code Dockerfile so a yolo agent can't flush the firewall).
  //  - fixOwnership: re-align /opt to the runtime vscode uid (updateRemoteUserUID side effect).
  //  - firewall: Apptainer shares the container netns, so this OUTPUT allowlist governs the workflow too.
  "postStartCommand": {
    "fixOwnership": "sudo /usr/local/bin/fix-opt-ownership.sh",
    "firewall": "sudo /usr/local/bin/start-firewall.sh"
  },
  "waitFor": "postStartCommand"
}
